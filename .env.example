# Copy this file to .env and fill in real values.
# The .env file is gitignored - never commit it.

# Local Postgres password used by docker-compose.
POSTGRES_PASSWORD=azen

# MinIO credentials for local S3-compatible storage.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# JWT signing secret. Long random string.
# In production, generate with: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-string-for-local-dev
