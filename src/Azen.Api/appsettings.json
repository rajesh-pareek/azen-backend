{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "App": {
    "Name": "Azen Backend API",
    "Version": "v1"
  },
  "ConnectionStrings": {
    "AuthDb": "Server=localhost,1433;Database=AzenAuthDb;User Id=sa;Password='YOUR_PASSWORD';TrustServerCertificate=True;",
    "AppDb": "Server=localhost,1433;Database=AzenAppDb;User Id=sa;Password='YOUR_PASSWORD';TrustServerCertificate=True;"
  },
  "Jwt": {
    "Secret": "YOUR_JWT_SECRET_AT_LEAST_32_CHARACTERS_LONG",
    "Issuer": "Azen.Api",
    "Audience": "Azen.Mobile",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 30
  },
  "FeatureFlags": {
    "UseRealSMS": false
  },
  "SmsProvider": {
    "ApiKey": "YOUR_2FACTOR_API_KEY"
  },
  "Storage": {
    "Endpoint": "http://localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "BucketName": "azen-documents",
    "UseSSL": false
  },
  "Cors": {
    "AllowedOrigins": []
  }
}
